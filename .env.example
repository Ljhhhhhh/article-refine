# Obsidian Vault (改成你的真实路径)
LINK_PROCESSING_VAULT=/path/to/obsidian-vault

# Proxy (可选，国内环境访问 Twitter 等需要)
# HTTPS_PROXY=http://127.0.0.1:7890

# LLM Provider: mock | openai
LINK_PROCESSING_LLM_PROVIDER=openai
LINK_PROCESSING_LLM_MODEL=Qwen3.5-4B-OptiQ-4bit

# OpenAI-compatible API
OPENAI_API_KEY=8888
OPENAI_BASE_URL=http://127.0.0.1:11435/v1
