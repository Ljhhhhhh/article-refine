{
  "name": "link-processing-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "link-processing": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup src/cli/index.ts --format esm --dts --clean --out-dir dist/cli",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mozilla/readability": "latest",
    "cheerio": "latest",
    "commander": "latest",
    "jsdom": "latest",
    "yaml": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/jsdom": "latest",
    "@types/node": "latest",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
