{
  "name": "link-processing-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "link-processing": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli/index.ts --format esm --dts --clean --out-dir dist",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@mozilla/readability": "latest",
    "cheerio": "latest",
    "commander": "latest",
    "dotenv": "^17.4.2",
    "jsdom": "latest",
    "openai": "^6.37.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "undici": "^8.2.0",
    "yaml": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/jsdom": "latest",
    "@types/node": "latest",
    "@types/turndown": "^5.0.6",
    "aws-sdk-client-mock": "^4.1.0",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
