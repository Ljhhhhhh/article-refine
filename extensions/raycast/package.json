{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "link-processing",
  "title": "LinkProcessingAgent",
  "description": "Save a URL into Obsidian by invoking the local LinkProcessingAgent CLI.",
  "icon": "extension-icon.png",
  "author": "guanmo",
  "categories": ["Productivity", "Developer Tools"],
  "license": "MIT",
  "commands": [
    {
      "name": "save-url",
      "title": "Save URL to Obsidian",
      "description": "Process a URL with LinkProcessingAgent CLI",
      "mode": "no-view",
      "arguments": [
        {
          "name": "url",
          "type": "text",
          "placeholder": "https://example.com/article",
          "required": true
        }
      ]
    }
  ],
  "preferences": [
    {
      "name": "projectPath",
      "title": "Project Path",
      "type": "textfield",
      "required": true,
      "default": "/Users/guanmo/Documents/projects/linkProcessing",
      "placeholder": "/Users/guanmo/Documents/projects/linkProcessing"
    },
    {
      "name": "runtime",
      "title": "Runtime",
      "type": "dropdown",
      "required": true,
      "default": "source",
      "data": [
        { "title": "Source via pnpm exec tsx", "value": "source" },
        { "title": "Built dist CLI via node", "value": "dist" }
      ]
    },
    {
      "name": "duplicatePolicy",
      "title": "Duplicate Policy",
      "type": "dropdown",
      "required": true,
      "default": "create",
      "data": [
        { "title": "Create New Note", "value": "create" },
        { "title": "Skip Existing Note", "value": "skip" },
        { "title": "Update Existing Note", "value": "update" }
      ]
    },
    {
      "name": "ossEnabled",
      "title": "Mirror to OSS",
      "type": "checkbox",
      "required": false,
      "default": true
    },
    {
      "name": "timeoutSeconds",
      "title": "Timeout Seconds",
      "type": "textfield",
      "required": true,
      "default": "180",
      "placeholder": "180"
    }
  ],
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix"
  },
  "dependencies": {
    "@raycast/api": "^1.93.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.8.0"
  }
}
